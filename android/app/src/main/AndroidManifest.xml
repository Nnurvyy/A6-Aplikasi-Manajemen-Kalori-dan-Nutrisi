<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ── Izin Health Connect (READ only) ───────────────────────────────── -->
    <!-- WAJIB: deklarasikan semua tipe data yang akan dibaca dari Health Connect -->
    <uses-permission android:name="android.permission.health.READ_STEPS"/>
    <uses-permission android:name="android.permission.health.READ_HEART_RATE"/>
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED"/>
    <uses-permission android:name="android.permission.health.READ_OXYGEN_SATURATION"/>
    <!-- ─────────────────────────────────────────────────────────────────── -->

    <application
        android:label="nutritrack_app"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme"/>

            <!-- Intent launcher utama app -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

            <!-- PERBAIKAN 1: Intent filter untuk menampilkan dialog penjelasan izin -->
            <!-- Tanpa ini, Health Connect tidak tahu ke mana harus redirect       -->
            <!-- saat user menekan "Pelajari lebih lanjut" di dialog permission     -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>

        </activity>

        <!-- PERBAIKAN 2: Activity khusus untuk handle alur request permission      -->
        <!-- Health Connect membutuhkan activity ini untuk membuka dialog izin       -->
        <!-- Tanpa ini: requestAuthorization() langsung return false tanpa dialog    -->
        <activity
            android:name="androidx.health.connect.client.PermissionController$HealthDataRequestPermissionsActivity"
            android:exported="true"/>

        <!-- PERBAIKAN 3: URL Privacy Policy — WAJIB sejak Android 14 / Health Connect v2 -->
        <!-- Tanpa ini app masuk kategori "Perlu diupdate" dan izin selalu ditolak          -->
        <!-- Buat halaman di Google Sites (gratis) lalu isi URL-nya di sini                 -->
        <!-- Contoh: https://sites.google.com/view/nutritrack-privacy/home                  -->
        <meta-data
            android:name="health_connect_privacy_policy_url"
            android:value="https://sites.google.com/view/nutritrack-privacy-policy/halaman-muka"/>

        <!-- Meta Flutter embedding (bawaan, jangan diubah) -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2"/>

        <!-- ML Kit untuk barcode scanning (bawaan, jangan diubah) -->
        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="barcode"/>

    </application>

    <!-- ── Queries: WAJIB di luar <application> ──────────────────────────── -->
    <queries>
        <!-- PERBAIKAN 4: Tambah package Health Connect secara eksplisit          -->
        <!-- Android 11+ membutuhkan deklarasi ini agar app bisa "melihat"        -->
        <!-- dan berkomunikasi dengan app Health Connect yang terinstall di HP     -->
        <package android:name="com.google.android.apps.healthdata"/>

        <!-- Intent Process Text (bawaan Flutter, jangan diubah) -->
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
    <!-- ─────────────────────────────────────────────────────────────────── -->

</manifest>